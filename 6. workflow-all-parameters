# 🚀 ✅ FULL REAL EXAMPLE (Everything Combined)

```yaml
name: Full Demo

on:
  workflow_dispatch:

env:
  APP_NAME: entrust

jobs:
  build:
    runs-on: ubuntu-latest

    outputs:
      version: ${{ steps.set.outputs.version }}

    steps:
      - uses: actions/checkout@v4

      - id: set
        run: echo "version=v1.0" >> $GITHUB_OUTPUT

  deploy:
    runs-on: ubuntu-latest
    needs: build

    steps:
      - name: Print version
        run: echo "Deploying ${{ needs.build.outputs.version }}"
```

